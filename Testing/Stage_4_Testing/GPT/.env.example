# Database storage path (relative to project root)
DATABASE_FILE=./data/schedule.sqlite

# Gmail OAuth 2.0 credentials (fill these in)
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here
GMAIL_SENDER_EMAIL=your_email@gmail.com

# Optional override for Gmail API base URL (not required in most cases)
GMAIL_API_BASE_URL=https://gmail.googleapis.com
